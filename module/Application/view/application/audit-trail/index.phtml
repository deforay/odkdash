<script type="text/javascript">
    function validateNow() {
        var flag = deforayValidator.init({ formId: 'auditTrail' });
        return !!flag;
    }

    $(document).ready(function() {
        $('.audit-feed').on('click', '.audit-toggle', function() {
            $(this).closest('.audit-item').toggleClass('expanded');
        });

        var $search = $('#searchBox');
        var $wrap = $('#searchWrap');
        var $items = $('.audit-feed .audit-item');
        var debounce = null;

        function applyFilter() {
            var term = ($search.val() || '').trim().toLowerCase();
            $wrap.toggleClass('has-value', term.length > 0);
            if (!term) {
                $items.show();
                $('.audit-feed .day-group').show();
                return;
            }
            $items.each(function() {
                var hay = $(this).attr('data-search') || '';
                $(this).toggle(hay.indexOf(term) !== -1);
            });
            $('.audit-feed .day-group').each(function() {
                $(this).toggle($(this).find('.audit-item:visible').length > 0);
            });
        }

        $search.on('input', function() {
            clearTimeout(debounce);
            debounce = setTimeout(applyFilter, 150);
        });
        $('#clearSearch').on('click', function() {
            $search.val('').focus();
            applyFilter();
        });
    });
</script>

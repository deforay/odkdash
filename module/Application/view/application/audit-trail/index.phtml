<?php

use Laminas\Session\Container;

$sessionLogin = new Container('credo');

$auditRows    = $result['auditInfo'] ?? [];
$auditColumns = array_column($result['auditColumns'] ?? [], 'COLUMN_NAME');

$version       = $params['version'] ?? '';
$metaInstance  = trim($params['metaInstance'] ?? '');

$metaCols = ['action', 'revision', 'dt_datetime', 'id'];

$entries = [];
foreach ($auditRows as $i => $snap) {
    $changes = [];
    if ($i > 0) {
        $prev = $auditRows[$i - 1];
        foreach ($auditColumns as $col) {
            if (in_array($col, $metaCols, true)) {
                continue;
            }
            $a = (string) ($prev[$col] ?? '');
            $b = (string) ($snap[$col] ?? '');
            if ($a !== $b) {
                $changes[] = ['field' => $col, 'from' => $a, 'to' => $b];
            }
        }
    }
    $entries[] = [
        'action'   => $snap['action'] ?? 'update',
        'revision' => $snap['revision'] ?? null,
        'datetime' => $snap['dt_datetime'] ?? null,
        'changes'  => $changes,
        'isFirst'  => $i === 0,
    ];
}
$entries = array_reverse($entries);

$groups = [];
foreach ($entries as $e) {
    $ts = strtotime($e['datetime'] ?? 'now');
    $key = date('Y-m-d', $ts);
    if (!isset($groups[$key])) {
        $groups[$key] = [
            'label' => date('D, j M Y', $ts),
            'items' => [],
        ];
    }
    $groups[$key]['items'][] = $e + ['ts' => $ts];
}
?>

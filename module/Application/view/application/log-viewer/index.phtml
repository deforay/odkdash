    <div class="logviewer-grid">
        <aside class="logviewer-files">
            <h2><?= $this->translate('Log files') ?></h2>
            <?php if (empty($files)) : ?>
                <div class="empty"><?= $this->translate('No log files yet.') ?></div>
            <?php else : ?>
                <ul id="lv-file-list">
                    <?php foreach ($files as $i => $f) : ?>
                        <li>
                            <button type="button"
                                    data-file="<?= $this->escapeHtmlAttr($f['name']) ?>"
                                    class="lv-file-btn<?= $i === 0 ? ' active' : '' ?>">
                                <span class="filename"><?= $this->escapeHtml($f['name']) ?></span>
                                <span class="meta">
                                    <?= $this->escapeHtml(number_format($f['size'] / 1024, 1)) ?> KB ·
                                    <?= $this->escapeHtml(date('M j, H:i', $f['modified'])) ?>
                                </span>
                            </button>
                        </li>
                    <?php endforeach; ?>
                </ul>
            <?php endif; ?>
        </aside>

        <section class="logviewer-content">
            <div class="logviewer-toolbar">
                <div>
                    <label for="lv-search"><?= $this->translate('Search') ?></label>
                    <input type="text" id="lv-search" placeholder="<?= $this->translate('case-insensitive substring filter') ?>" autocomplete="off">
                </div>
                <div>
                    <label for="lv-lines"><?= $this->translate('Lines') ?></label>
                    <select id="lv-lines">
                        <option value="100">100</option>
                        <option value="500" selected>500</option>
                        <option value="1000">1000</option>
                        <option value="2500">2500</option>
                        <option value="<?= (int) $maxLines ?>"><?= (int) $maxLines ?></option>
                    </select>
                </div>
                <button type="button" id="lv-refresh" class="btn btn-primary"><?= $this->translate('Refresh') ?></button>
                <button type="button" id="lv-clear" class="btn btn-secondary"><?= $this->translate('Clear filter') ?></button>
            </div>
            <div class="logviewer-status" id="lv-status"></div>
            <pre class="logviewer-pre empty" id="lv-output"><?= $this->translate('Pick a log file on the left to begin.') ?></pre>
        </section>
    </div>
</div>

<script>
(function () {
    var endpoint = '<?= $this->url('log-viewer') ?>';
    var currentFile = null;
    var refreshDebounce = null;

    function $(id) { return document.getElementById(id); }

    function setActive(name) {
        document.querySelectorAll('.lv-file-btn').forEach(function (b) {
            b.classList.toggle('active', b.dataset.file === name);
        });
    }

    function clearChildren(node) {
        while (node.firstChild) node.removeChild(node.firstChild);
    }

    function renderLines(lines, search) {
        var pre = $('lv-output');
        pre.classList.remove('empty');
        clearChildren(pre);

        if (!lines || lines.length === 0) {
            pre.classList.add('empty');
            pre.appendChild(document.createTextNode(
                search ? 'No matches for "' + search + '".' : 'File is empty.'
            ));
            return;
        }

        var fragment = document.createDocumentFragment();
        var needle = search ? search.toLowerCase() : '';

        lines.forEach(function (line) {
            var span = document.createElement('span');
            span.className = 'lv-line';
            if (/\.ERROR:|\.CRITICAL:/.test(line)) span.classList.add('lv-error');
            else if (/\.WARNING:/.test(line)) span.classList.add('lv-warning');
            else if (/\.INFO:/.test(line)) span.classList.add('lv-info');

            if (needle) {
                var lower = line.toLowerCase();
                var idx = lower.indexOf(needle);
                var cursor = 0;
                while (idx !== -1) {
                    span.appendChild(document.createTextNode(line.substring(cursor, idx)));
                    var hl = document.createElement('span');
                    hl.className = 'lv-hl';
                    hl.textContent = line.substring(idx, idx + needle.length);
                    span.appendChild(hl);
                    cursor = idx + needle.length;
                    idx = lower.indexOf(needle, cursor);
                }
                span.appendChild(document.createTextNode(line.substring(cursor)));
            } else {
                span.textContent = line;
            }
            fragment.appendChild(span);
        });
        pre.appendChild(fragment);
        pre.scrollTop = pre.scrollHeight;
    }

    function setStatus(text) {
        $('lv-status').textContent = text || '';
    }

    function load(name) {
        if (!name) return;
        currentFile = name;
        setActive(name);
        setStatus('Loading…');

        var params = new URLSearchParams({
            format: 'json',
            file: name,
            lines: $('lv-lines').value,
            q: $('lv-search').value.trim(),
        });

        fetch(endpoint + '?' + params.toString(), {
            credentials: 'same-origin',
            headers: { 'Accept': 'application/json' },
        })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (data.error) {
                    setStatus('Error: ' + data.error);
                    return;
                }
                var status = data.count + ' lines';
                if (data.search) status += ' matching "' + data.search + '"';
                status += ' · ' + (data.file.size / 1024).toFixed(1) + ' KB total';
                setStatus(status);
                renderLines(data.lines, data.search);
            })
            .catch(function (err) {
                setStatus('Request failed: ' + err.message);
            });
    }

    document.addEventListener('click', function (e) {
        var btn = e.target.closest('.lv-file-btn');
        if (btn) load(btn.dataset.file);
    });

    $('lv-refresh').addEventListener('click', function () { load(currentFile); });
    $('lv-clear').addEventListener('click', function () { $('lv-search').value = ''; load(currentFile); });
    $('lv-search').addEventListener('input', function () {
        clearTimeout(refreshDebounce);
        refreshDebounce = setTimeout(function () { load(currentFile); }, 300);
    });
    $('lv-lines').addEventListener('change', function () { load(currentFile); });

    var first = document.querySelector('.lv-file-btn');
    if (first) load(first.dataset.file);
})();
</script>

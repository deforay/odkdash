<script src="<?php echo $this->basePath('assets/js/daterangepicker.js'); ?>"></script>
<script type="text/javascript">
(function() {
    var feedUrl = "<?php echo $this->url('event-log', ['action' => 'index']); ?>";

    var state = {
        page: 1,
        pageSize: 25,
        startDate: '',
        endDate: '',
        eventType: '',
        search: ''
    };

    function classifyAction(eventType) {
        var t = (eventType || '').toLowerCase();
        if (t.indexOf('login-failed') !== -1 || t.indexOf('failed') !== -1) return 'failed';
        if (t.indexOf('log-out') !== -1 || t.indexOf('logout') !== -1) return 'logout';
        if (t.indexOf('login') !== -1) return 'login';
        if (t.indexOf('add') !== -1 || t.indexOf('create') !== -1 || t.indexOf('insert') !== -1) return 'create';
        if (t.indexOf('delete') !== -1 || t.indexOf('remove') !== -1) return 'delete';
        if (t.indexOf('update') !== -1 || t.indexOf('edit') !== -1) return 'update';
        if (t.indexOf('download') !== -1 || t.indexOf('export') !== -1) return 'download';
        if (t.indexOf('email') !== -1 || t.indexOf('mail') !== -1 || t.indexOf('message') !== -1) return 'message';
        return 'other';
    }

    var iconFor = {
        create:   'fa-plus',
        delete:   'fa-trash-o',
        update:   'fa-pencil',
        login:    'fa-sign-in',
        failed:   'fa-exclamation-triangle',
        logout:   'fa-sign-out',
        download: 'fa-download',
        message:  'fa-paper-plane-o',
        other:    'fa-circle-o'
    };

    var $feed = $('#auditFeed');
    var $summary = $('#auditSummary');
    var $pagination = $('#auditPagination');
    var $pageInfo = $('#pageInfo');
    var $prev = $('#prevBtn');
    var $next = $('#nextBtn');
    var fetchSeq = 0;
    var searchDebounce = null;

    function escapeHtml(text) {
        if (text === null || text === undefined) return '';
        return String(text)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }

    function highlight(text, term) {
        var safe = escapeHtml(text);
        if (!term) return safe;
        var trimmed = term.trim();
        if (!trimmed) return safe;
        var parts = trimmed.split(/\s+/).map(function(p) {
            return p.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        }).filter(Boolean);
        if (!parts.length) return safe;
        var re = new RegExp('(' + parts.join('|') + ')', 'gi');
        return safe.replace(re, '<mark class="audit-hit">$1</mark>');
    }

    function renderItem(item, term) {
        var actionClass = classifyAction(item.eventType);
        var iconClass = iconFor[actionClass] || iconFor.other;
        var contextHtml = item.eventType
            ? '<span class="audit-context">' + escapeHtml(item.eventType) + '</span>'
            : '';
        return ''
            + '<div class="audit-item">'
            +   '<div class="audit-icon ' + actionClass + '">'
            +     '<i class="fa ' + iconClass + '"></i>'
            +   '</div>'
            +   '<div class="audit-body">'
            +     '<div class="audit-action">' + highlight(item.action, term) + '</div>'
            +     '<div class="audit-meta">'
            +       '<span class="audit-user" title="' + escapeHtml(item.userLogin) + '">'
            +         '<span class="audit-avatar">' + escapeHtml(item.userInitials) + '</span>'
            +         '<span class="audit-user-name">' + highlight(item.userName, term) + '</span>'
            +       '</span>'
            +       contextHtml
            +     '</div>'
            +   '</div>'
            +   '<div class="audit-time" title="' + escapeHtml(item.datetime) + '">' + escapeHtml(item.time) + '</div>'
            + '</div>';
    }

    function renderFeed(payload) {
        if (!payload.items || payload.items.length === 0) {
            $feed.html('<div class="empty-state"><i class="fa fa-folder-open-o"></i>No events match the current filters.</div>');
            $summary.html('<strong>0</strong> events');
            $pagination.hide();
            return;
        }

        var groups = [];
        var current = null;
        payload.items.forEach(function(item) {
            if (!current || current.key !== item.dateKey) {
                current = { key: item.dateKey, label: item.dateLabel, items: [] };
                groups.push(current);
            }
            current.items.push(item);
        });

        var term = state.search;
        var html = '';
        groups.forEach(function(g) {
            html += '<div class="day-group">';
            html +=   '<div class="day-header">' + escapeHtml(g.label) + ' <span class="count">' + g.items.length + '</span></div>';
            g.items.forEach(function(it) { html += renderItem(it, term); });
            html += '</div>';
        });

        $feed.html(html);

        var start = (payload.page - 1) * payload.pageSize + 1;
        var end = Math.min(start + payload.items.length - 1, payload.total);
        $summary.html('<strong>' + payload.total.toLocaleString() + '</strong> events');
        $pageInfo.html('Showing <strong>' + start + '</strong>–<strong>' + end + '</strong> of <strong>' + payload.total.toLocaleString() + '</strong>');
        $prev.prop('disabled', payload.page <= 1);
        $next.prop('disabled', payload.page >= payload.totalPages);
        $pagination.show();
    }

    function fetchFeed() {
        var seq = ++fetchSeq;
        $feed.html('<div class="loading-state"><i class="fa fa-circle-o-notch fa-spin"></i>Loading…</div>');
        $.ajax({
            url: feedUrl,
            type: 'POST',
            dataType: 'json',
            data: state
        }).done(function(payload) {
            if (seq !== fetchSeq) return;
            renderFeed(payload);
        }).fail(function() {
            if (seq !== fetchSeq) return;
            $feed.html('<div class="empty-state"><i class="fa fa-exclamation-triangle"></i>Failed to load events. Please retry.</div>');
            $pagination.hide();
        });
    }

    $(document).ready(function() {
        $('#dateRange').daterangepicker({
            locale: { cancelLabel: 'Clear', format: 'DD-MMM-YYYY', separator: ' to ' },
            autoApply: true,
            showDropdowns: true,
            alwaysShowCalendars: true,
            autoUpdateInput: false,
            ranges: {
                'Today':         [moment(), moment()],
                'Yesterday':     [moment().subtract(1, 'days'), moment().subtract(1, 'days')],
                'Last 7 Days':   [moment().subtract(6, 'days'), moment()],
                'Last 30 Days':  [moment().subtract(29, 'days'), moment()],
                'This Month':    [moment().startOf('month'), moment().endOf('month')],
                'Last Month':    [moment().subtract(1, 'month').startOf('month'), moment().subtract(1, 'month').endOf('month')]
            }
        }, function(start, end) {
            state.startDate = start.format('DD-MMM-YYYY');
            state.endDate = end.format('DD-MMM-YYYY');
            state.page = 1;
            $('#dateRange').val(state.startDate + ' to ' + state.endDate);
            fetchFeed();
        });

        $('#dateRange').on('cancel.daterangepicker', function() {
            $(this).val('');
            state.startDate = '';
            state.endDate = '';
            state.page = 1;
            fetchFeed();
        });

        $('#eventType').on('change', function() {
            state.eventType = $(this).val();
            state.page = 1;
            fetchFeed();
        });

        $('#searchBox').on('input', function() {
            var val = $(this).val();
            $('#searchWrap').toggleClass('has-value', val.length > 0);
            clearTimeout(searchDebounce);
            searchDebounce = setTimeout(function() {
                state.search = val;
                state.page = 1;
                fetchFeed();
            }, 250);
        });

        $('#clearSearch').on('click', function() {
            $('#searchBox').val('').focus();
            $('#searchWrap').removeClass('has-value');
            state.search = '';
            state.page = 1;
            fetchFeed();
        });

        $('#pageSize').on('change', function() {
            state.pageSize = parseInt($(this).val(), 10) || 25;
            state.page = 1;
            fetchFeed();
        });

        $prev.on('click', function() {
            if (state.page > 1) {
                state.page -= 1;
                fetchFeed();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        });

        $next.on('click', function() {
            state.page += 1;
            fetchFeed();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        $('#resetBtn').on('click', function() {
            $('#dateRange').val('');
            $('#eventType').val('');
            $('#searchBox').val('');
            $('#searchWrap').removeClass('has-value');
            state = { page: 1, pageSize: state.pageSize, startDate: '', endDate: '', eventType: '', search: '' };
            fetchFeed();
        });

        fetchFeed();
    });
})();
</script>

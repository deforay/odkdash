                    <span><strong>Source:</strong> <span class="mono" id="metaSource">—</span></span>
                    <span><strong>Request ID:</strong> <span class="mono" id="metaReqId">—</span></span>
                    <span><strong>Duration:</strong> <span id="metaDuration">—</span></span>

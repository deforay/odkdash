</div>

<script>
(function() {
    var LIST_URL  = "<?php echo $listUrl; ?>";
    var SHOW_URL  = "<?php echo $showUrl; ?>";
    var STATS_URL = "<?php echo $statsUrl; ?>";

    var state = { page: 1, perPage: 50, sort: 'created_at', dir: 'desc',
                  filters: { method:'', status:'', source:'', url:'', slow:'', from:'' } };
    var autoTimer = null;

    function escapeHtml(v) {
        if (v === null || v === undefined) return '';
        return String(v).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function methodBadge(m) {
        var cls = ['GET','POST','PUT','DELETE'].indexOf(m) >= 0 ? m : 'OTHER';
        return '<span class="method-badge method-' + cls + '">' + escapeHtml(m || '?') + '</span>';
    }

    function statusBadge(code, hasError) {
        var c = parseInt(code, 10) || 0;
        var bucket = c === 0 ? '0' : (Math.floor(c/100) + 'xx');
        var label = c || (hasError ? 'ERR' : '—');
        return '<span class="status-badge status-' + bucket + '">' + label + '</span>';
    }

    function fmtTime(ts) {
        if (!ts) return '';
        var d = new Date(ts.replace(' ', 'T') + 'Z');
        if (isNaN(d.getTime())) return ts;
        return d.toLocaleString(undefined, { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit', second:'2-digit', hour12: false });
    }

    function refreshStats() {
        $.getJSON(STATS_URL, function(s) {
            $('#statTotal').text((s.total_requests||0).toLocaleString());
            var rate = s.error_rate || 0;
            $('#statErrRate').text(rate + '%').removeClass('warn danger ok')
                .addClass(rate > 5 ? 'danger' : (rate > 1 ? 'warn' : 'ok'));
            $('#statAvg').text((s.avg_duration_ms||0) + 'ms');
            $('#statP95').text((s.p95_duration_ms||0) + 'ms').removeClass('warn danger')
                .addClass((s.p95_duration_ms||0) > 2000 ? 'warn' : '');
        });
    }

    function refreshList() {
        var q = $.extend({ page: state.page, per_page: state.perPage, sort: state.sort, dir: state.dir, format: 'json' }, state.filters);
        $.getJSON(LIST_URL, q, function(resp) {
            renderRows(resp.rows || []);
            $('#totalCount').text((resp.total || 0).toLocaleString());
            var start = (state.page - 1) * state.perPage + 1;
            var end = Math.min(start + (resp.rows||[]).length - 1, resp.total || 0);
            $('#pageInfo').text((resp.total ? start + '–' + end + ' of ' + resp.total : '0 results'));
            $('#prevPage').prop('disabled', state.page <= 1);
            $('#nextPage').prop('disabled', end >= (resp.total || 0));
            updateSortIndicators();
        });
    }

    function renderRows(rows) {
        if (!rows.length) {
            $('#apilogBody').html('<tr><td colspan="6" style="padding:28px;text-align:center;color:#a0aec0;">No calls match these filters.</td></tr>');
            return;
        }
        var html = rows.map(function(r) {
            var slow = (r.duration_ms || 0) > 2000 ? ' style="color:#d97706;"' : '';
            var errTag = r.error ? '<span class="err-tag" title="' + escapeHtml(r.error) + '">err</span>' : '';
            return '<tr data-id="' + escapeHtml(r.request_id) + '">' +
                '<td class="mono">' + escapeHtml(fmtTime(r.created_at)) + '</td>' +
                '<td>' + methodBadge(r.method) + '</td>' +
                '<td class="mono url-cell" title="' + escapeHtml(r.url || '') + '">' + escapeHtml(r.url || '') + '</td>' +
                '<td>' + statusBadge(r.response_code, !!r.error) + errTag + '</td>' +
                '<td class="mono"' + slow + '>' + (r.duration_ms || 0) + 'ms</td>' +
                '<td><span class="source-pill">' + escapeHtml(r.source || '—') + '</span></td>' +
                '</tr>';
        }).join('');
        $('#apilogBody').html(html);
    }

    function updateSortIndicators() {
        $('.apilog-table th').each(function() {
            var col = $(this).data('sort');
            var ind = $(this).find('.sort-ind');
            if (!col) { ind.text(''); return; }
            if (col === state.sort) {
                ind.text(state.dir === 'asc' ? '▲' : '▼').addClass('active');
            } else {
                ind.text('').removeClass('active');
            }
        });
    }

    function openDetail(id) {
        $.getJSON(SHOW_URL, { id: id }, function(row) {
            $('#modalMethod').attr('class', '').addClass('method-badge')
                .addClass('method-' + (['GET','POST','PUT','DELETE'].indexOf(row.method) >= 0 ? row.method : 'OTHER'))
                .text(row.method || '?');
            $('#modalUrl').text(row.url || '');
            var code = parseInt(row.response_code, 10) || 0;
            var bucket = code === 0 ? '0' : Math.floor(code/100) + 'xx';
            $('#modalStatus').attr('class', 'status-badge status-' + bucket).text(code || (row.error ? 'ERR' : '—'));
            $('#modalSubtitle').text((row.request_id || '') + ' · ' + (row.duration_ms || 0) + 'ms · ' + fmtTime(row.created_at));

            if (row.error) {
                $('#modalErrorWrap').show();
                $('#modalError').text(row.error);
            } else {
                $('#modalErrorWrap').hide();
            }

            renderBody('#modalRequestBody', row.request_body, 'No request body (likely a GET).');
            renderBody('#modalResponseBody', row.response_body, row.error ? 'Connection failed before any response.' : 'No response body captured.');

            $('#metaSource').text(row.source || '—');
            $('#metaReqId').text(row.request_id || '—');
            $('#metaDuration').text((row.duration_ms || 0) + ' ms');

            $('#apilogModal').data('reqBody', row.request_body).data('resBody', row.response_body);
            $('#apilogModal').modal('show');
        });
    }

    function renderBody(sel, raw, emptyMsg) {
        var $el = $(sel);
        if (raw === null || raw === undefined || raw === '') {
            $el.html('<div class="apilog-empty">' + escapeHtml(emptyMsg) + '</div>');
            return;
        }
        $el.html('<pre></pre>');
        $el.find('pre').text(prettyJson(raw));
    }

    function prettyJson(raw) {
        if (raw === null || raw === undefined) return '';
        try {
            var parsed = typeof raw === 'string' ? JSON.parse(raw) : raw;
            return JSON.stringify(parsed, null, 2);
        } catch (e) {
            return String(raw);
        }
    }

    $(document).on('click', '#apilogBody tr[data-id]', function() {
        openDetail($(this).data('id'));
    });

    $('.apilog-table th[data-sort]').on('click', function() {
        var col = $(this).data('sort');
        if (state.sort === col) {
            state.dir = state.dir === 'asc' ? 'desc' : 'asc';
        } else {
            state.sort = col; state.dir = 'desc';
        }
        state.page = 1;
        refreshList();
    });

    var filterDebounce;
    $('#apilogToolbar').on('change input', 'input,select', function() {
        clearTimeout(filterDebounce);
        filterDebounce = setTimeout(function() {
            state.filters.method = $('#fMethod').val();
            state.filters.status = $('#fStatus').val();
            state.filters.source = $('#fSource').val();
            state.filters.url    = $('#fUrl').val();
            state.filters.slow   = $('#fSlow').val();
            state.filters.from   = $('#fFrom').val();
            state.page = 1;
            refreshList();
        }, 350);
    });

    $('#fClear').on('click', function() {
        $('#apilogToolbar')[0].reset();
        state.filters = { method:'', status:'', source:'', url:'', slow:'', from:'' };
        state.page = 1;
        refreshList();
    });

    $('#prevPage').on('click', function() { if (state.page > 1) { state.page--; refreshList(); } });
    $('#nextPage').on('click', function() { state.page++; refreshList(); });

    $('#apilogRefreshBtn').on('click', function() {
        var $b = $(this);
        if (autoTimer) {
            clearInterval(autoTimer); autoTimer = null;
            $b.removeClass('on').html('<i class="fa fa-refresh"></i> Auto-refresh OFF');
        } else {
            autoTimer = setInterval(function() { refreshList(); refreshStats(); }, 10000);
            $b.addClass('on').html('<i class="fa fa-refresh fa-spin"></i> Auto-refresh ON');
        }
    });

    $('.copy-btn').on('click', function() {
        var which = $(this).data('copy');
        var raw = which === 'req' ? $('#apilogModal').data('reqBody') : $('#apilogModal').data('resBody');
        if (!raw) return;
        var text = prettyJson(raw);
        navigator.clipboard && navigator.clipboard.writeText(text);
        var $b = $(this); var orig = $b.html();
        $b.html('<i class="fa fa-check"></i> copied');
        setTimeout(function() { $b.html(orig); }, 1500);
    });

    refreshList();
    refreshStats();
})();
</script>
